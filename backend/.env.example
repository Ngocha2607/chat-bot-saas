# ── Server ──────────────────────────────────────────────
PORT=3000

# ── Facebook / Meta Messenger ───────────────────────────
# Verify token: tự đặt 1 chuỗi bất kỳ, khai báo giống hệt trong Meta App > Webhooks
FB_VERIFY_TOKEN=my_verify_token_change_me
# App Secret (Meta App > Settings > Basic) — dùng để verify chữ ký X-Hub-Signature-256
FB_APP_SECRET=your_app_secret
# Page Access Token (Phase 1: 1 page test). Phase 2 sẽ chuyển sang lưu DB theo tenant.
FB_PAGE_ACCESS_TOKEN=your_page_access_token
# Graph API version
FB_GRAPH_API_VERSION=v21.0

# ── Gemini (Google AI Studio, free tier) ────────────────
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# ── Database (Phase 2+) ─────────────────────────────────
DATABASE_URL=postgresql://mbs:mbs_dev_password@localhost:5432/messenger_bot

# ── Redis / Queue (Phase 3+) ────────────────────────────
REDIS_URL=redis://localhost:6379
